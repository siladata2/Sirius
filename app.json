{
  "name": "SIRIUS WhatsApp Bot",
  "description": "Advanced WhatsApp Bot with automation features",
  "repository": "https://github.com/yourusername/sirius-bot",
  "logo": "https://i.ibb.co/BKZGzcbr/Sila-cipher.jpg",
  "keywords": ["whatsapp", "bot", "sirius", "whatsapp-bot", "baileys"],
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID (get from https://session.silamd.tech)",
      "required": true,
      "value": ""
    },
    "PREFIX": {
      "description": "Command prefix (default: .)",
      "required": false,
      "value": "."
    },
    "BOT_NAME": {
      "description": "Bot display name",
      "required": false,
      "value": "SIRIUS"
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number (optional, will auto-set)",
      "required": false,
      "value": ""
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
